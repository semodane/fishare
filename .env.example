## Database (PostgreSQL)
#
# Local example (Docker):
# - user: postgres
# - password: postgres
# - db: fishare
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fishare?schema=public"

## Auth.js (Auth / NextAuth v5)
#
# Required in production:
AUTH_SECRET="change-me"
AUTH_URL="http://localhost:3000"
AUTH_USE_PRISMA_ADAPTER="true"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Kakao OAuth
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# Note: Login buttons are enabled based on `/api/auth/providers` response.
# (No client-side "READY" flags needed.)

