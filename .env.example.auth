## Auth.js (Auth / NextAuth v5)
#
# Required in production:
AUTH_SECRET="change-me"
AUTH_URL="http://localhost:3000"

# Enable DB sessions + Prisma adapter
AUTH_USE_PRISMA_ADAPTER="true"

# Google (Social Login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Kakao (Social Login)
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# Note: Login buttons are enabled based on `/api/auth/providers` response.
# (No client-side "READY" flags needed.)

